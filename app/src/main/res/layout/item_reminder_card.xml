<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_card"
    android:orientation="horizontal"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvReminderIcon"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/bg_btn_warning"
        android:gravity="center"
        android:text="⏰"
        android:textSize="20sp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvReminderMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Revisar estado del reporte"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvReminderTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/muted"
            android:textSize="12sp" />
    </LinearLayout>

    <Button
        android:id="@+id/btnCancelReminder"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_btn_danger"
        android:text="Cancelar"
        android:textColor="@color/danger"
        android:textSize="11sp"
        android:padding="8dp" />
</LinearLayout>