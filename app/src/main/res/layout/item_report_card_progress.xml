<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_card"
    android:orientation="horizontal"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvReportIcon"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/bg_report_icon"
        android:gravity="center"
        android:text="B"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:textSize="18sp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvReportTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Basura acumulada en el parque central"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvReportMeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Categoría: Aseo · Evidencia adjunta · Hace 6 h"
            android:textColor="@color/muted"
            android:textSize="12sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:background="@drawable/bg_status_progress"
        android:paddingHorizontal="10dp"
        android:paddingVertical="6dp"
        android:text="En proceso"
        android:textColor="#A16207"
        android:textSize="11sp"
        android:textStyle="bold" />
</LinearLayout>