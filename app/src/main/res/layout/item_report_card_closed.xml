<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_card"
    android:orientation="horizontal"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvReportIcon"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/bg_report_icon"
        android:gravity="center"
        android:text="F"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:textSize="18sp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvReportTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Fuga de agua frente al bloque B"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvReportMeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Categoría: Servicios · Seguimiento activo · Hoy"
            android:textColor="@color/muted"
            android:textSize="12sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:background="@drawable/bg_status_closed"
        android:paddingHorizontal="10dp"
        android:paddingVertical="6dp"
        android:text="Cerrado"
        android:textColor="@color/success"
        android:textSize="11sp"
        android:textStyle="bold" />
</LinearLayout>